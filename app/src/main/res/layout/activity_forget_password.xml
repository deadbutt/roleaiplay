<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/home_back"
    tools:context=".ForgetPasswordActivity">

    <include layout="@layout/top_use_all"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/forget_password_2"
                android:textColor="@color/text_black"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="12dp"
                android:textSize="40sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/forget_password_3"
                android:textColor="@color/text_black"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp"
                android:textSize="16sp"/>

            <!--输入email-->
            <LinearLayout
                android:id="@+id/li_forget_password_email"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/xml_white_circle_back"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="20dp"
                    android:src="@drawable/icon_register_home_email"/>

                <EditText
                    android:id="@+id/cet_forget_password_email"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:textColor="@color/text_black"
                    android:gravity="center_vertical"
                    android:background="@null"
                    android:hint="@string/register_home_9"
                    android:textColorHint="#66131F27"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="20dp"
                    android:textSize="16sp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/ctv_forget_password_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/forget_password_4"
                android:textColor="@color/error_show_text"
                android:visibility="invisible"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="10dp"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/ctv_forget_password_submit"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:text="@string/register_home_12"
                android:textSize="20dp"
                android:gravity="center"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:textColor="@color/gray_button_back"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/xml_login_button_gray_back"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>