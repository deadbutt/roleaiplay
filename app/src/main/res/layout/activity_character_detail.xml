<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/character_background"
    tools:context=".CharacterDetailActivity">

    <!-- TopAppBar -->
    <include
        layout="@layout/top_app_bar"
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentTop="true" />

    <!-- Fixed Bottom Start Button -->
    <FrameLayout
        android:id="@+id/bottom_button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_bottom_gradient"
        android:padding="32dp"
        android:paddingBottom="32dp">

        <Button
            android:id="@+id/btn_start_conversation"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/start_conversation"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

    </FrameLayout>

    <!-- ScrollView 放在 TopAppBar 和 BottomButton 之间 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topAppBar"
        android:layout_above="@id/bottom_button_container"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="40dp"
            android:paddingBottom="120dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Hero Avatar Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp">

                <LinearLayout
                    android:layout_width="256dp"
                    android:layout_height="256dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_border"
                    android:padding="2dp">

                    <ImageView
                        android:id="@+id/iv_character_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_avatar_placeholder"
                        android:contentDescription="@string/character_portrait" />

                </LinearLayout>

            </FrameLayout>

            <!-- Character Identity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/featured_character"
                    android:textColor="@color/character_secondary"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_character_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/character_on_surface"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:lineHeight="36sp"
                    android:fontFamily="sans-serif" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/tv_tag_linguist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="@string/tag_linguist"
                        android:textColor="@color/character_on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:background="@drawable/bg_tag"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_tag_historian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="@string/tag_historian"
                        android:textColor="@color/character_on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:background="@drawable/bg_tag" />

                </LinearLayout>

            </LinearLayout>

            <!-- Character Description Block -->

            <!-- Environment Description Block -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_character_card"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.1"
                    android:text="角色特征"
                    android:textAllCaps="true"
                    android:textColor="@color/character_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_character_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:lineHeight="28sp"
                    android:text=""
                    android:textColor="@color/character_on_surface_variant"
                    android:textSize="18sp"
                    android:textStyle="italic" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="48dp"
                android:layout_marginEnd="0dp"
                android:layout_marginStart="0dp"
                android:background="@drawable/bg_environment_card"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="环境"
                    android:textColor="@color/character_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_environment_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/character_on_surface_variant"
                    android:textSize="18sp"
                    android:lineHeight="28sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>