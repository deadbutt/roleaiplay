<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/home_back"
    tools:context=".ChatActivity">


    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="30dp">

            <!-- Nexus AI 标题栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_chat_menu"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="10dp"
                    android:src="@drawable/icon_menu"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="zzz v1"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/xml_green_dot"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="qwen2.5-7b 已连接"
                            android:textColor="@color/text_gray"
                            android:textSize="10sp"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_new_session"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="1dp"
                    android:padding="10dp"
                    android:src="@drawable/icon_add"
                    app:tint="@color/blue_text"/>

                <ImageView
                    android:id="@+id/iv_chat_settings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="10dp"
                    android:src="@drawable/icon_settings"/>
            </LinearLayout>

            <!-- 日期分割线 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026年04月17日"
                    android:textSize="10sp"
                    android:textColor="@color/text_gray"
                    android:background="@drawable/xml_date_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- AI 欢迎消息 -->
            <LinearLayout
                android:id="@+id/ll_welcome_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/ll_ai_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/xml_ai_avatar_bg"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/icon_ai_star"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_ai_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nexus AI"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_gray"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/xml_ai_bubble"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="你好！我是你的 AI 助手。今天有什么可以帮你的吗？"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 用户消息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                android:gravity="end">




            </LinearLayout>

            <!-- AI 回复消息 -->
            <LinearLayout
                android:id="@+id/ll_ai_response"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/xml_ai_avatar_bg"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/icon_ai_star"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nexus AI"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_gray"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_ai_bubble"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/xml_ai_bubble"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_ai_response"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <!-- 代码块 -->
                    <LinearLayout
                        android:id="@+id/ll_code_block"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/xml_code_bg"
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_code_content"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#93C5FD"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_code_explanation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- 操作栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_regenerate"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:padding="8dp"
                            android:src="@drawable/icon_refresh"/>

                        <ImageView
                            android:id="@+id/iv_copy_code"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:padding="8dp"
                            android:src="@drawable/icon_copy"/>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="16dp"
                            android:background="@color/line_gray"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"/>

                        <ImageView
                            android:id="@+id/iv_like_code"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:padding="8dp"
                            android:src="@drawable/icon_like"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 重新生成按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/ctv_regenerate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重新生成响应"
                    android:textSize="12sp"
                    android:textColor="@color/blue_text"
                    android:background="@drawable/xml_regenerate_bg"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:drawableStart="@drawable/icon_restart"
                    android:drawablePadding="8dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- 底部输入区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/xml_input_bg"
                    android:padding="8dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iv_add"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/icon_add"/>

                    <EditText
                        android:id="@+id/cet_message_input"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="问问 Nexus..."
                        android:textColor="@color/text_black"
                        android:textColorHint="#66131F27"
                        android:textSize="14sp"
                        android:maxLines="4"
                        android:inputType="textMultiLine"
                        android:paddingVertical="8dp"/>

                    <ImageView
                        android:id="@+id/iv_mic"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/icon_microphone"/>

                    <ImageView
                        android:id="@+id/iv_send"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/icon_send"
                        android:background="@drawable/xml_send_bg"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nexus 可能产生错误信息，请核实重要数据。"
                    android:textSize="9sp"
                    android:textColor="@color/text_gray"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="20dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>