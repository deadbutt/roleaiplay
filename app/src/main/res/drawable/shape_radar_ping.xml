<?xml version="1.0" encoding="utf-8"?>
<!-- 雷达: width: 220px; height: 154px; border-radius: 50% -->
<!-- background: radial-gradient(circle at 50% 50%, rgba(255, 223, 184, .9) 0 5px, transparent 6px), repeating-radial-gradient, radial-gradient -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外层光晕: radial-gradient(circle at 50% 50%, rgba(255, 193, 113, .08), transparent 65%) -->
    <item>
        <shape android:shape="oval">
            <gradient android:gradientRadius="65%" android:centerX="0.5" android:centerY="0.5" android:startColor="#14FFC171" android:endColor="#00FFC171" />
        </shape>
    </item>
    <!-- 同心圆环: repeating-radial-gradient(circle at 50% 50%, transparent 0 25px, rgba(255,255,255,.1) 26px 27px) -->
    <item android:left="25dp" android:right="25dp" android:top="25dp" android:bottom="25dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
    <item android:left="50dp" android:right="50dp" android:top="50dp" android:bottom="50dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
    <!-- 中心点: radial-gradient(circle at 50% 50%, rgba(255, 223, 184, .9) 0 5px, transparent 6px) -->
    <item android:left="70dp" android:right="70dp" android:top="70dp" android:bottom="70dp">
        <shape android:shape="oval">
            <solid android:color="#E6FFDFB8" />
        </shape>
    </item>
</layer-list>