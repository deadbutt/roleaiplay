<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#05080d"
                android:endColor="#020409" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#09FFD091"
                android:endColor="#00FFD091"
                android:centerX="0.5"
                android:centerY="0.2"
                android:gradientRadius="34%" />
        </shape>
    </item>
</layer-list>