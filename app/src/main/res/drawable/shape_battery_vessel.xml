<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 电池外壳: border: 4px solid rgba(255,255,255,.55); border-radius: 17px 17px 22px 22px -->
    <item>
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="12dp" android:topRightRadius="12dp" android:bottomLeftRadius="16dp" android:bottomRightRadius="16dp" />
            <stroke android:width="3dp" android:color="#8CFFFFFF" />
            <gradient android:angle="0" android:startColor="#33FFFFFF" android:centerColor="#0D000000" android:centerX="0.5" android:endColor="#38FFFFFF" />
        </shape>
    </item>
    <!-- 内部光泽 -->
    <item android:left="3dp" android:right="3dp" android:top="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="9dp" android:topRightRadius="9dp" android:bottomLeftRadius="13dp" android:bottomRightRadius="13dp" />
            <gradient android:angle="0" android:startColor="#47FFFFFF" android:centerColor="#00FFFFFF" android:centerX="0.18" android:endColor="#3DFFFFFF" />
        </shape>
    </item>
    <!-- 电池盖: width: 62px; height: 20px; top: -22px; border-radius: 7px 7px 2px 2px -->
    <item android:left="25dp" android:right="25dp" android:top="-14dp" android:bottom="140dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="5dp" android:topRightRadius="5dp" android:bottomLeftRadius="1dp" android:bottomRightRadius="1dp" />
            <gradient android:angle="270" android:startColor="#D9D9D9" android:endColor="#4D4F52" />
            <stroke android:width="1.5dp" android:color="#80FFFFFF" />
        </shape>
    </item>
</layer-list>